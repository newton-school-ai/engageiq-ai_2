# EngageIQ AI - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://localhost:5432/engageiq_dev

# =============================================================================
# LLM PROVIDERS (pick one - Groq recommended for free tier)
# =============================================================================

# Groq (recommended - free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier available - https://aistudio.google.com)
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# Ollama (local, no API key needed - https://ollama.ai)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# OpenAI (paid - uncomment if you have a key)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (paid - uncomment if you have a key)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# DEFAULT LLM SELECTION
# =============================================================================
LLM_PROVIDER=groq

# =============================================================================
# WEBCAM SETTINGS
# =============================================================================
WEBCAM_INDEX=0
WEBCAM_FPS=15
WEBCAM_RESOLUTION=640x480

# =============================================================================
# ENGAGEMENT SCORING
# =============================================================================
GAZE_WEIGHT=0.30
POSE_WEIGHT=0.20
EXPRESSION_WEIGHT=0.25
ALERTNESS_WEIGHT=0.25

# =============================================================================
# NUDGE SETTINGS
# =============================================================================
NUDGE_COOLDOWN_SECONDS=300
MAX_NUDGES_PER_SESSION=5
NUDGE_TRIGGER_DURATION_SECONDS=30

# =============================================================================
# PRIVACY
# =============================================================================
# local_only = all data stays on student device (default)
# share_with_teacher = anonymized scores shared with teacher
DEFAULT_PRIVACY_MODE=local_only

# =============================================================================
# APPLICATION
# =============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=change_this_to_a_random_string_in_production

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# FRONTEND
# =============================================================================
FRONTEND_URL=http://localhost:5173
